{
  "manifest_version": 3,
  "name": "FolderTab",
  "version": "1.0.0",
  "description": "New Tab customizável com sistema de pastas para seus sites favoritos",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "permissions": [
    "storage",
    "favicon",
    "tabs"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}